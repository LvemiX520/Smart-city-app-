<view class="news"><view class="news-tab"><scroll-view class="news-tab-scroll" scroll-x="true" scroll-with-animation="{{true}}"><block wx:for="{{news.list}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" data-event-params="{{({item})}}" class="{{['news-tab-scroll-box',id==item.id?'active':'']}}" bindtap="__e"><text class="{{['news-tab-scroll-box-text',index!=5?'line':'']}}">{{item.name}}</text></view></block></scroll-view></view><view class="news-element"><block wx:for="{{all.list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block wx:if="{{item.type==id}}"><view data-event-opts="{{[['tap',[['TapNew',['$0'],[[['all.list','',index,'id']]]]]]]}}" class="news-element-box" bindtap="__e"><image src="{{ip+item.cover}}" mode></image><text>{{item.title}}</text></view></block></block></view></view>