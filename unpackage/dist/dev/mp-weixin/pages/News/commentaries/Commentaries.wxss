@charset "UTF-8";
/**
 * 下方引入的为uView UI的集成样式文件，为scss预处理器，其中包含了一些"u-"开头的自定义变量
 * 使用的时候，请将下面的一行复制到您的uniapp项目根目录的uni.scss中即可
 * uView自定义的css类名和scss变量，均以"u-"开头，不会造成冲突，请放心使用 
 */
.C-box {
  display: flex;
  flex-direction: column;
}
.C-box .C-box-bgcolor {
  background-color: #f5f5f5;
}
.C-box .C-box-bgcolor .C-box-input {
  margin: 20rpx;
  background-color: #fff;
  display: flex;
  flex-direction: row;
  height: 80rpx;
}
.C-box .C-box-bgcolor .C-box-input input {
  text-indent: 1em;
  flex: 1;
  height: 100%;
  border: 2rpx solid #dbdbdb;
}
.C-box .C-box-bgcolor .C-box-input button {
  background-color: #007aff;
  color: #fff;
}
.C-box .C-box-text {
  flex: 1;
  flex-direction: column;
}
.C-box .C-box-text .C-box-text-box {
  display: flex;
  border-bottom: 2rpx solid #d6d6d6;
}
.C-box .C-box-text .C-box-text-box .C-box-text-text {
  font-size: 16rpx;
}
.C-box .C-box-text .C-box-text-box .box-n {
  flex: 1;
  display: flex;
  flex-direction: row;
  height: 150rpx;
}
.C-box .C-box-text .C-box-text-box .box-n .box-n-left {
  flex: 0.5;
}
.C-box .C-box-text .C-box-text-box .box-n .box-n-right {
  flex: 3;
  display: flex;
  flex-direction: column;
}

